# Frontend build-time environment variables (Vite).
# Copy to `frontend/.env` for local overrides (gitignored). Vite only exposes
# variables prefixed with VITE_ to the client bundle.

# Base URL of the deployed backend API. If unset, the app uses the relative
# `/api` path (Vite dev proxy). Set this in Vercel for production builds.
# Must include the trailing `/api`, e.g. https://your-backend.onrender.com/api
VITE_API_URL=https://your-backend.onrender.com/api
