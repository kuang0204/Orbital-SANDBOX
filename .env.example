# Backend environment variables (Django).
# Copy this file to `.env` for local development and fill in real values.
# `.env` is gitignored — never commit real secrets.
# In production (Render), set these in the service's Environment dashboard.

# Postgres/Supabase connection string. If unset, the app falls back to local
# SQLite (db.sqlite3), so local dev works without setting this.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Django secret key. Generate a fresh one for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret

# Set to False in production. Defaults to True if unset (local dev).
DEBUG=True

# Comma-separated hostnames Django will serve. Add your Render URL in prod.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated allowed CORS origins. Only used when DEBUG=False.
# Set this to your deployed frontend URL, e.g. https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
